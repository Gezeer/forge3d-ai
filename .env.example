# RunPod-compatible defaults
FORGE3D_ENV=development
FORGE3D_UPLOAD_DIR=/workspace/forge3d-ai/uploads
FORGE3D_OUTPUT_DIR=/workspace/forge3d-ai/outputs
FORGE3D_JOBS_FILE=/workspace/forge3d-ai/outputs/jobs.json
FORGE3D_TRIPOSR_RUN=/workspace/kai3d/models/TripoSR/run.py
FORGE3D_TRIPOSR_PYTHON=/workspace/kai3d/models/Hunyuan3D-2.1/venv/bin/python
FORGE3D_TRIPOSR_DEVICE=cuda:0
FORGE3D_HUNYUAN_URL=http://127.0.0.1:8080
FORGE3D_HUNYUAN_ENDPOINT=/run/shape_generation
FORGE3D_HUNYUAN_RETRY_ATTEMPTS=5
FORGE3D_HUNYUAN_RETRY_BASE_SECONDS=0.5
FORGE3D_HUNYUAN_ROOT=/workspace/kai3d/models/Hunyuan3D-2.1
FORGE3D_HUNYUAN_PYTHON=/workspace/kai3d/models/Hunyuan3D-2.1/venv/bin/python
FORGE3D_HUNYUAN_PORT=8080
FORGE3D_HUNYUAN_CACHE_PATH=/tmp/hunyuan-cache
FORGE3D_HUNYUAN_START_TIMEOUT_SECONDS=300
FORGE3D_HUNYUAN_STOP_TIMEOUT_SECONDS=30
FORGE3D_HUNYUAN_LOG=/tmp/hunyuan-shape.log
FORGE3D_GPU_LOCK_PATH=/tmp/forge3d-gpu.lock
FORGE3D_GPU_LOCK_TIMEOUT_SECONDS=1800

FORGE3D_GENERATION_TIMEOUT_SECONDS=900
FORGE3D_UPLOAD_MAX_BYTES=20971520
FORGE3D_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
FORGE3D_CORS_ORIGINS=http://localhost:3000
FORGE3D_CORS_ORIGIN_REGEX=^https://[a-z0-9-]+-(3000|8000)\.proxy\.runpod\.net$
FORGE3D_QUEUE_CONCURRENCY=1
FORGE3D_QUEUE_MAX_SIZE=100
FORGE3D_DEFAULT_ENGINE=auto
FORGE3D_AUTO_ENGINE_FALLBACK=triposr
FORGE3D_LOG_LEVEL=INFO
FORGE3D_LOG_FORMAT=text
FORGE3D_METRICS_ENABLED=true
FORGE3D_HEALTH_TIMEOUT_SECONDS=10
FORGE3D_TEXTURE_ROOT=/workspace/kai3d/models/Hunyuan3D-2.1
FORGE3D_ROOT=/workspace/forge3d-ai
FORGE3D_BLENDER_EXECUTABLE=/usr/bin/blender
FORGE3D_TEXTURE_PYTHON=/workspace/kai3d/models/Hunyuan3D-2.1/venv/bin/python
FORGE3D_TEXTURE_CACHE=/workspace/.cache/forge3d-texture
FORGE3D_TEXTURE_TIMEOUT_SECONDS=1800
FORGE3D_TEXTURE_DOWNLOAD_ATTEMPTS=4
FORGE3D_TEXTURE_DOWNLOAD_RETRY_SECONDS=2
FORGE3D_TEXTURE_MIN_FREE_BYTES=3221225472
FORGE3D_TEXTURE_PIPELINE_VERSION=hunyuan3d-2.1
