# RunPod-compatible defaults
FORGE3D_ENV=development
FORGE3D_UPLOAD_DIR=/workspace/forge3d-ai/uploads
FORGE3D_OUTPUT_DIR=/workspace/forge3d-ai/outputs
FORGE3D_JOBS_FILE=/workspace/forge3d-ai/outputs/jobs.json
FORGE3D_TRIPOSR_RUN=/workspace/kai3d/models/TripoSR/run.py
FORGE3D_TRIPOSR_PYTHON=/workspace/kai3d/models/Hunyuan3D-2.1/venv/bin/python
FORGE3D_TRIPOSR_DEVICE=cuda:0
FORGE3D_HUNYUAN_URL=http://127.0.0.1:8080
FORGE3D_HUNYUAN_API_NAME=/generation_all

# Fill this only after inspecting the real Gradio API on RunPod.
# Use {"$image":true} exactly where the uploaded image belongs.
FORGE3D_HUNYUAN_SIGNATURE_JSON=

FORGE3D_GENERATION_TIMEOUT_SECONDS=900
FORGE3D_UPLOAD_MAX_BYTES=20971520
FORGE3D_ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/webp
FORGE3D_CORS_ORIGINS=http://localhost:3000
FORGE3D_QUEUE_CONCURRENCY=1
FORGE3D_QUEUE_MAX_SIZE=100
FORGE3D_DEFAULT_ENGINE=auto
FORGE3D_AUTO_ENGINE_FALLBACK=triposr
